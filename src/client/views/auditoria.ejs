<%- include('partials/head', { title: tabelaParam ? 'Auditoria — ' + tabelaParam : 'Auditoria' }) %>
<%- include('partials/nav') %>

<h1>Auditoria<%= tabelaParam ? ' — ' + tabelaParam : ' de Dados' %></h1>

<form method="get" action="/auditoria" style="margin-bottom:20px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
  <select name="tabela" class="form-control" style="width:auto">
    <option value="">— Selecione uma tabela —</option>
    <% for (const t of tabelaNomes) { %>
      <option value="<%= t %>" <%= t === tabelaParam ? 'selected' : '' %>><%= t %></option>
    <% } %>
  </select>
  <%# btn-local: var(--color-primary) = #1e6fbf, contraste 5.2:1 sobre branco → passa WCAG AA
      Anterior #3498db = 3.1:1 → falhava AA %>
  <button type="submit" class="btn-local">Comparar</button>
</form>

<% if (error) { %>
  <div class="empty"><p><%= error %></p></div>
<% } else if (tabelaParam && rows) { %>

  <div style="margin-bottom:12px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
    <span style="font-size:13px;color:var(--color-text-muted)">
      <span style="color:var(--color-success);font-weight:bold"><%= totalOk %> iguais</span> &nbsp;|&nbsp;
      <span style="color:var(--color-danger);font-weight:bold"><%= totalDif %> diferente(s)</span> &nbsp;|&nbsp;
      <span style="color:var(--color-warning);font-weight:bold"><%= totalAusente %> ausente(s) na filial</span>
    </span>
    <% if (temDivergencias) { %>
      <button onclick="corrigir('<%= tabelaParam %>', <%= offset %>, 'matriz')"
              class="btn-local">
        Aplicar Matriz em Tudo
      </button>
      <button onclick="corrigir('<%= tabelaParam %>', <%= offset %>, 'manual')"
              class="btn-servidor">
        Resolver um por um (Conflitos)
      </button>
    <% } %>
    <small style="color:#aaa;font-size:11px">Vermelho = filial difere — valor do servidor exibido abaixo em cinza</small>
  </div>

  <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;background:white;font-size:12px;box-shadow:0 1px 3px rgba(0,0,0,.1)">
      <thead style="background:#f0f0f0;text-transform:uppercase;color:#555">
        <tr>
          <th style="padding:8px 10px;text-align:left"><%= pkLabel %></th>
          <% for (const col of todasColunas) { %>
            <th style="padding:8px 10px;text-align:left"><%= col %></th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% for (const row of rows) { %>
          <% if (!row.loc) { %>
            <tr style="background:#fff3cd">
              <td><%= row.pkValor %></td>
              <td colspan="<%= todasColunas.length %>" style="color:#856404;font-style:italic">
                Não existe na filial
              </td>
            </tr>
          <% } else { %>
            <tr style="<%= row.difColunas.length > 0 ? 'background:#f8d7da' : '' %>">
              <td><strong style="<%= row.difColunas.length > 0 ? 'font-weight:bold' : '' %>"><%= row.pkValor %></strong></td>
              <% for (const col of todasColunas) { %>
                <% const isDif = row.difColunas.includes(col); %>
                <td>
                  <% if (isDif) { %>
                    <%# Valor da filial em destaque — não depende apenas de cor (WCAG 1.4.1) %>
                    <span style="color:var(--color-error-text,#6b1212);font-weight:bold;display:block">
                      <%- formatDisplay(row.loc[col]) %>
                    </span>
                    <%# Valor do servidor visível em texto — antes só acessível via hover/tooltip %>
                    <span style="color:#888;font-size:11px;display:block;margin-top:2px">
                      ↑ Srv: <%= String(row.srv[col] != null ? row.srv[col] : 'NULL') %>
                    </span>
                  <% } else { %>
                    <%# color:var(--color-text-muted) = ~5.9:1 sobre branco → passa WCAG AA
                        Anterior color:#aaa = 2.32:1 → falhava AA %>
                    <span style="color:var(--color-text-muted)"><%- formatDisplay(row.loc[col]) %></span>
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% } %>
        <% } %>
      </tbody>
    </table>
  </div>

  <div style="margin-top:16px;display:flex;gap:8px">
    <% if (offset > 0) { %>
      <a href="/auditoria?tabela=<%= tabelaParam %>&offset=<%= Math.max(0, offset - limite) %>"
         style="padding:6px 14px;background:#eee;border-radius:4px;text-decoration:none;font-size:13px">← Anterior</a>
    <% } %>
    <% if (temProxima) { %>
      <a href="/auditoria?tabela=<%= tabelaParam %>&offset=<%= proxOffset %>"
         style="padding:6px 14px;background:#eee;border-radius:4px;text-decoration:none;font-size:13px">Próxima →</a>
    <% } %>
    <span style="font-size:12px;color:var(--color-text-muted);margin-left:8px;align-self:center">
      Registros <%= offset + 1 %>–<%= offset + rows.length %>
    </span>
  </div>

<% } %>

<%- include('partials/scripts') %>
