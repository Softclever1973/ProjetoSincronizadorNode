<script>
  /**
   * _notificarErro — substitui alert() nativo por feedback inline acessível.
   * Insere role="alert" após o botão de origem e remove automaticamente.
   */
  function _notificarErro(btn, mensagem) {
    var id = '_err_' + Math.random().toString(36).slice(2);
    var el = document.createElement('span');
    el.id = id;
    el.setAttribute('role', 'alert');
    el.style.cssText = 'color:var(--color-danger,#b91c1c);font-size:12px;margin-left:8px;font-weight:600;display:inline-block;margin-top:4px';
    el.textContent = mensagem;
    if (btn && btn.parentNode) btn.parentNode.insertBefore(el, btn.nextSibling);
    else document.body.appendChild(el);
    setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 6000);
  }

  async function corrigir(tabela, offset, escolha) {
    escolha = escolha || 'matriz';
    var btn = event.target;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.classList.add('btn-loading');
    btn.setAttribute('aria-label', 'Processando correção...');
    try {
      var r = await fetch('/auditoria/corrigir', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tabela: tabela, offset: offset, escolha: escolha })
      });
      var data = await r.json();
      if (data.ok) {
        if (escolha === 'manual') {
          window.location.href = '/';
        } else {
          btn.classList.remove('btn-loading');
          btn.textContent = 'Concluído: ' + data.processados + ' registro(s)';
          btn.setAttribute('aria-label', originalText);
          setTimeout(function() { location.reload(); }, 1500);
        }
      } else {
        _notificarErro(btn, 'Erro: ' + (data.message || 'desconhecido'));
        btn.disabled = false;
        btn.classList.remove('btn-loading');
        btn.textContent = originalText;
        btn.setAttribute('aria-label', originalText);
      }
    } catch(e) {
      _notificarErro(btn, 'Erro de rede: ' + e.message);
      btn.disabled = false;
      btn.classList.remove('btn-loading');
      btn.textContent = originalText;
      btn.setAttribute('aria-label', originalText);
    }
  }

  async function resolver(id, escolha) {
    var btn = event.target;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.classList.add('btn-loading');
    btn.setAttribute('aria-label', 'Processando resolução do conflito...');
    try {
      var r = await fetch('/conflitos/' + id + '/resolver', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ escolha: escolha })
      });
      var data = await r.json();
      if (data.ok) {
        location.reload();
      } else {
        _notificarErro(btn, 'Erro: ' + (data.message || 'desconhecido'));
        btn.disabled = false;
        btn.classList.remove('btn-loading');
        btn.textContent = originalText;
        btn.setAttribute('aria-label', originalText);
      }
    } catch(e) {
      _notificarErro(btn, 'Erro de rede: ' + e.message);
      btn.disabled = false;
      btn.classList.remove('btn-loading');
      btn.textContent = originalText;
      btn.setAttribute('aria-label', originalText);
    }
  }

  async function resolverMesclado(conflitoid) {
    var campos = {};
    document.querySelectorAll('[name^="campo-' + conflitoid + '-"]').forEach(function(r) {
      if (r.checked) {
        var col = r.name.replace('campo-' + conflitoid + '-', '');
        campos[col] = r.value;
      }
    });
    var btn = event.target;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.classList.add('btn-loading');
    btn.setAttribute('aria-label', 'Aplicando mesclagem...');
    try {
      var r = await fetch('/conflitos/' + conflitoid + '/resolver', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ escolha: 'mesclar', campos: campos })
      });
      var data = await r.json();
      if (data.ok) {
        location.reload();
      } else {
        _notificarErro(btn, 'Erro: ' + (data.message || 'desconhecido'));
        btn.disabled = false;
        btn.classList.remove('btn-loading');
        btn.textContent = originalText;
        btn.setAttribute('aria-label', originalText);
      }
    } catch(e) {
      _notificarErro(btn, 'Erro de rede: ' + e.message);
      btn.disabled = false;
      btn.classList.remove('btn-loading');
      btn.textContent = originalText;
      btn.setAttribute('aria-label', originalText);
    }
  }

  // ── SSE: badges e notificações em tempo real ─────────────────────────────
  (function () {
    fetch('/api/erros/count')
      .then(function(r) { return r.json(); })
      .then(function(d) { atualizarBadgeErros(d.total); })
      .catch(function() {});

    fetch('/api/conflitos/count')
      .then(function(r) { return r.json(); })
      .then(function(d) { atualizarBadgeConflitos(d.total); })
      .catch(function() {});

    if ('Notification' in window && Notification.permission === 'default') {
      Notification.requestPermission();
    }

    var es = new EventSource('/eventos');

    es.addEventListener('novo-erro', function(e) {
      try {
        var erro = JSON.parse(e.data);
        var badge = document.getElementById('erros-badge');
        var atual = badge ? (parseInt(badge.textContent, 10) || 0) : 0;
        atualizarBadgeErros(atual + 1);
        if ('Notification' in window && Notification.permission === 'granted') {
          new Notification('Erro de Sincronização', {
            body: (erro.tabela ? '[' + erro.tabela + '] ' : '') + erro.mensagem,
            tag: 'sync-erro-' + (erro.tabela || 'geral'),
          });
        }
      } catch (_) {}
    });

    es.addEventListener('novo-conflito', function(e) {
      try {
        var c = JSON.parse(e.data);
        var badge = document.getElementById('conflitos-badge');
        var atual = badge ? (parseInt(badge.textContent, 10) || 0) : 0;
        atualizarBadgeConflitos(atual + 1);
        if ('Notification' in window && Notification.permission === 'granted') {
          new Notification('Conflito de Sincronização', {
            body: (c.tabela ? '[' + c.tabela + '] ' : '') + 'PK: ' + c.pkValor,
            tag: 'sync-conflito-' + (c.tabela || 'geral'),
          });
        }
      } catch (_) {}
    });

    es.onerror = function() {};
  })();

  function atualizarBadgeErros(total) {
    var badge = document.getElementById('erros-badge');
    if (!badge) return;
    if (total > 0) { badge.textContent = total; badge.style.display = 'inline'; }
    else { badge.style.display = 'none'; }
  }

  function atualizarBadgeConflitos(total) {
    var badge = document.getElementById('conflitos-badge');
    if (!badge) return;
    if (total > 0) { badge.textContent = total; badge.style.display = 'inline'; }
    else { badge.style.display = 'none'; }
  }

  // ── Toggle de conflitos — event delegation (P0-D / CSP) ──────────────────
  // Substitui onclick inline por listener delegado, compatível com
  // Content-Security-Policy script-src 'self'. Usa .hidden (semântico) em
  // vez de style.display, para que leitores de tela tratem o painel como
  // ausente da árvore de acessibilidade quando colapsado.
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-toggle-target]');
    if (!btn) return;
    var target = document.getElementById(btn.dataset.toggleTarget);
    if (!target) return;
    var aberto = btn.getAttribute('aria-expanded') === 'true';
    target.hidden = aberto;
    btn.setAttribute('aria-expanded', String(!aberto));
    var icon = btn.querySelector('.toggle-icon');
    if (icon) icon.textContent = aberto ? '▼ Ver detalhes' : '▲ Ocultar';
  });
</script>
</body>
</html>
