# Token de autenticação entre cliente (filial) e servidor (matriz).
# Deve ser idêntico nos dois lados.
SYNC_TOKEN=seu-token-aqui

# Conexão PostgreSQL do servidor (matriz). Não usado pelo cliente (filial usa sirius-client.ini).
DATABASE_URL=postgresql://postgres:senha@localhost:5432/matriz

# Porta HTTP do servidor Express (padrão: 8080)
PORT=8080

# Token para o endpoint admin POST /admin/reload-empresas (opcional)
ADMIN_TOKEN=seu-admin-token-aqui
