# ─── SERVIDOR (matriz) ────────────────────────────────────────────────────────
# Conexão PostgreSQL
DATABASE_URL=postgresql://postgres:senha@localhost:5432/matriz

# Porta HTTP do servidor Express (padrão: 8080)
PORT=8080

# Token para o endpoint admin POST /admin/reload-empresas (opcional)
ADMIN_TOKEN=seu-admin-token-aqui

# Segredo para assinar JWTs de usuários (obrigatório para autenticação de donos de empresas)
#npm run generate-secret   # gera um novo secret de 128 chars (64 bytes hex)
JWT_SECRET=sua-chave-secreta-aqui

# Senha especial exigida para resetar dados de uma empresa pelo painel super-admin.
# Compartilhe apenas com supervisores autorizados.
# Se não definida, o endpoint de reset ficará bloqueado (503).
RESET_SECRET=senha-supervisores-aqui

