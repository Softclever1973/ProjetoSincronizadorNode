{
  "name": "projeto-sincronizador-node",
  "version": "1.0.0",
  "description": "Servidor de sincronização Firebird matriz/filiais",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "client": "node src/client/index.js",
    "client:dev": "nodemon src/client/index.js",
    "generate-secret": "node -e \"process.stdout.write(require('crypto').randomBytes(64).toString('hex') + '\\n')\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "node-firebird": "^1.1.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "nodemonConfig": {
    "ignore": [
      "*.json",
      "*.ini",
      "conflitos.json",
      "tabelas-config.json"
    ]
  }
}
